# =============================================================================
# TAKSH Digital Smart Menu — Environment Variables (EXAMPLE / TEMPLATE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` (and/or `.env.local`) and fill in real values.
# NEVER commit `.env` or `.env.local` — they are gitignored.
#
# Prefix rules:
#   NEXT_PUBLIC_*  → inlined into the browser bundle. Only PUBLIC-SAFE values.
#   (no prefix)    → server-only. NEVER give a secret a NEXT_PUBLIC_ prefix.
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# URL and anon key are safe for the browser ONLY because RLS is enabled on every
# table. If you add a table, enable RLS + policies before shipping.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Bypasses RLS = full DB access.
# Never expose under a NEXT_PUBLIC_ prefix and never hardcode in source.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase management/CLI token (server only; used for migrations/tooling).
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# ── Image storage: Cloudflare R2 (S3-compatible) ─────────────────────────────
# All R2_* values except the public base URL are server-only secrets.
R2_BUCKET=your-bucket
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
# CDN host used by next/image remotePatterns (public).
NEXT_PUBLIC_IMAGE_CDN_HOST=res.tastefy.food

# Cloudflare API token (server only) — used for R2/CDN management.
CLOUDFLARE_API_KEY=your-cloudflare-api-token

# ── Cloudinary (optional legacy image path; server only) ─────────────────────
# CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Push notifications: OneSignal ────────────────────────────────────────────
# App ID is public (client SDK). REST API key is SERVER ONLY.
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ── Push notifications: Firebase FCM (legacy) ────────────────────────────────
# Firebase web config + VAPID public key are public by design.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-web-push-vapid-key
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
# Firebase Admin service account JSON — SERVER ONLY. Contains a private key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Web Push (VAPID) — public key is client-safe, private key is SERVER ONLY.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=you@example.com

# ── Google (server only) ─────────────────────────────────────────────────────
# Used only by /api/google-stats server route. Do NOT give this a NEXT_PUBLIC_ prefix.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_REVIEW_URL=https://google.com/maps/place/...

# ── Cron / scheduled jobs ────────────────────────────────────────────────────
# Shared secret to authorize /api/cron/notify. Server only.
CRON_SECRET=generate-a-long-random-string

# ── Analytics traffic gating (optional) ──────────────────────────────────────
# ANALYTICS_ALLOWED_HOSTS=tastefy.food,www.tastefy.food
# NEXT_PUBLIC_SITE_URL=https://tastefy.food
# NEXT_PUBLIC_APP_URL=https://tastefy.food
