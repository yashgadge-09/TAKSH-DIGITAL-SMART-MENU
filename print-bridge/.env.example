SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to true for mock (console) mode; false for real ESC/POS over TCP
MOCK_PRINT=true

# Printer IPs (only used when MOCK_PRINT=false)
KITCHEN_PRINTER_IP=192.168.1.100
RECEPTION_PRINTER_IP=192.168.1.101

# Poll interval in milliseconds
POLL_MS=2000
